active_profile: default
profiles:
  default:
    model: openai/gpt-oss-120b:free
    base_url: https://openrouter.ai/api/v1
    api_key: ${OPENROUTER_API_KEY}
    max_context_tokens: 120000
    default_followups: 1
    local_repo: ~/src/repo
    github_token: ${GITHUB_TOKEN}
    gitlab_token: ${GITLAB_TOKEN}
    gitlab_base_url: ${GITLAB_BASE_URL}
    review_system_prompt_file: ~/prompts/review_system.tmpl
    review_user_prompt_file: ~/prompts/review_user.tmpl
    followup_system_prompt_file: ~/prompts/followup_system.tmpl
    followup_user_prompt_file: ~/prompts/followup_user.tmpl
  local-llama:
    model: llama3
    base_url: http://localhost:11434/v1
    max_context_tokens: 8000
    default_followups: 0

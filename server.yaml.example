# nickpit gitlab serve configuration (--serve-config, default: server.yaml).
# ${VAR} references are expanded from the environment at load time.

# HTTP listen address for webhooks and /healthz.
listen: ":8080"

# Directory for per-review child process logs.
log_dir: "logs"

# Maximum parallel review child processes.
review_concurrency: 2

# How long running reviews may finish after SIGTERM before being terminated.
shutdown_grace: "10m"

# GitLab instance the webhooks come from and the reviews are posted to.
gitlab_base_url: "https://gitlab.example.com"

# Projects carrying this topic are auto-reviewed on MR activity.
topic: "nickpit"

# Awarding this emoji on an MR requests a review (any project, drafts too).
trigger_emoji: "nickpit"

# Emoji the daemon awards on the MR when a review starts ("" disables).
start_emoji: "eyes"

# Keyword for MR comment commands: /<keyword> review|abort|status|help.
command_keyword: "nickpit"

# Emoji the daemon awards on a command comment to acknowledge it ("" disables).
ack_emoji: "white_check_mark"

# Optional second YAML file whose top-level `groups:` list (same shape as
# below) is appended to the inline groups — lets the group inventory live
# apart from this file, e.g. in a mounted Kubernetes Secret. Env-expanded
# like this file. A relative path is resolved against this file's directory.
# groups_file: "/etc/nickpit/groups.yaml"

# One entry per GitLab group. Events are routed to the longest matching path
# prefix. token: group access token (role Developer, scope api); reviews are
# posted as its bot user. webhook_secret: the group webhook's secret token.
groups:
  - path: "platform"
    token: "${NICKPIT_GL_TOKEN_PLATFORM}"
    webhook_secret: "${NICKPIT_GL_SECRET_PLATFORM}"
  # Nested groups may carry their own token/secret; the longer prefix wins.
  # - path: "platform/legacy"
  #   token: "${NICKPIT_GL_TOKEN_LEGACY}"
  #   webhook_secret: "${NICKPIT_GL_SECRET_LEGACY}"

# Extra CLI arguments appended verbatim to every review child process. Chat
# children inherit these too (thread replies then run under the same
# profile/model as the review they discuss) unless chat.extra_args below
# replaces them. Use global (root-level) flags only; a review-subcommand-only
# flag would break every child at flag parsing.
review:
  extra_args: []
  # extra_args: ["--profile", "default", "--show-progress"]

# Discussion-agent (chat) replies: a reply inside a nickpit review thread
# spawns a `nickpit chat` child that answers it. Unlike reviews (opt-in per
# project topic), any commenter in such a thread triggers a paid LLM turn, so
# chat can be switched off entirely and its concurrency capped.
chat:
  enabled: true       # false acknowledges and drops chat replies; no LLM turn runs
  max_concurrent: 4   # concurrent chat child processes (<=0 uses the default 4)
  # extra_args replaces review.extra_args for chat children when present.
  # Absent (commented out) chat children inherit review.extra_args; an
  # explicit empty list [] forwards nothing.
  # extra_args: ["--profile", "default"]

# Optional: stream each review's output live to Grafana Loki (in addition to
# the on-disk log_dir file), so logs survive pod restarts and are queryable in
# Grafana. Streaming is enabled only when `url` is set. Credentials are
# env-expanded like the rest of this file, so no secret text need live here.
# loki:
#   url: "http://loki-gateway.monitoring:80"   # base URL; /loki/api/v1/push is appended
#   tenant_id: "${LOKI_TENANT}"                 # X-Scope-OrgID (multi-tenant Loki); optional
#   basic_auth_user: "${LOKI_USER}"             # optional; set with basic_auth_pass
#   basic_auth_pass: "${LOKI_PASS}"
#   labels:                                     # extra static labels (must not use app/project/iid/trigger)
#     env: "prod"
#   batch_wait: "1s"                            # flush a partial batch after this long
#   batch_max_lines: 1000                       # flush once a batch reaches this many lines
#   timeout: "10s"                              # per-push HTTP timeout
#   buffer_lines: 4096                          # per-review queue; lines drop (with a warning) when full
#   gzip: false
